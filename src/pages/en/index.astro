---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeContent from '../../components/HomeContent.astro';
import { medicalWebPage } from '../../lib/seo/schema';
import { useTranslations, localePath } from '../../i18n';

const locale = 'en' as const;
const t = useTranslations(locale);
const url = new URL(localePath(locale, '/'), Astro.site!).href;

const jsonLd = medicalWebPage({
  url,
  name: `${t.site.name} — ${t.site.tagline}`,
  description: t.home.subtitle,
  inLanguage: locale,
});
---

<BaseLayout
  title={`${t.site.name} — ${t.site.tagline}`}
  description={t.home.subtitle}
  locale={locale}
  path="/"
  jsonLd={jsonLd}
>
  <HomeContent locale={locale} />
</BaseLayout>
