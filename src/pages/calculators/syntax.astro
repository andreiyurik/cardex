---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyntaxPageContent from '../../components/SyntaxPageContent.astro';
import { medicalRiskCalculator } from '../../lib/seo/schema';
import { useTranslations, localePath } from '../../i18n';

const locale = 'ru' as const;
const t = useTranslations(locale);
const url = new URL(localePath(locale, '/calculators/syntax'), Astro.site!).href;

const jsonLd = medicalRiskCalculator({
  url,
  name: t.calculators.syntax.title,
  description: t.calculators.syntax.seoDescription,
  inLanguage: locale,
  estimatesRiskOf: 'Coronary artery disease',
});
---

<BaseLayout
  title={t.calculators.syntax.seoTitle}
  description={t.calculators.syntax.seoDescription}
  locale={locale}
  path="/calculators/syntax"
  jsonLd={jsonLd}
>
  <SyntaxPageContent locale={locale} />
</BaseLayout>
