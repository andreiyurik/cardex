---
import { ArrowRight, Calculator, WifiOff } from '@lucide/astro';
import { calculators } from '../lib/calculators/registry';
import { useTranslations, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Catalog is driven entirely by the calculator registry.
const items = calculators.map((c) => {
  const tc = (t.calculators as Record<string, any>)[c.i18nKey];
  return {
    href: localePath(locale, `/calculators/${c.slug}`),
    title: tc.title as string,
    description: tc.shortDescription as string,
  };
});
---

<section class="py-8">
  <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{t.home.title}</h1>
  <p class="text-base-content/70 mt-4 max-w-2xl text-lg leading-relaxed">
    {t.home.subtitle}
  </p>
  <p class="text-base-content/50 mt-3 inline-flex items-center gap-1.5 text-sm">
    <WifiOff class="size-4" aria-hidden="true" />
    {t.home.offlineReady}
  </p>
</section>

<section class="grid gap-4 sm:grid-cols-2">
  {
    items.map((c) => (
      <a
        href={c.href}
        class="group bg-base-200 border-base-300 hover:border-primary/60 rounded-box border p-5 transition-colors"
      >
        <Calculator class="text-primary size-6" aria-hidden="true" />
        <h2 class="mt-3 text-lg font-semibold">{c.title}</h2>
        <p class="text-base-content/60 mt-1 text-sm">{c.description}</p>
        <span class="text-primary mt-3 inline-flex items-center gap-1 text-sm font-medium">
          {t.home.openCalculator}
          <ArrowRight
            class="size-4 transition-transform group-hover:translate-x-0.5"
            aria-hidden="true"
          />
        </span>
      </a>
    ))
  }
</section>
