---
import { useTranslations, type Locale } from '../i18n';
import { CONTACT_EMAIL } from '../lib/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const d = t.disclaimer;
---

<article class="max-w-2xl space-y-4">
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{d.title}</h1>
  <p class="text-base-content/70 leading-relaxed">{d.p1}</p>
  <p class="text-base-content/70 leading-relaxed">{d.p2}</p>
  <p class="text-base-content/70 leading-relaxed">{d.p3}</p>
  <p class="text-base-content/70 leading-relaxed">{d.p4}</p>
  <p class="text-base-content/70 leading-relaxed">
    {d.p5}
    <a href={`mailto:${CONTACT_EMAIL}`} class="text-primary underline underline-offset-2">
      {CONTACT_EMAIL}
    </a>
  </p>
</article>
